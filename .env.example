# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Voyage AI (required for RAG: embedding user queries to search Corner Cases posts)
VOYAGE_API_KEY=your_voyage_api_key

# ============================================
# Steph Configuration (Optional)
# ============================================
# Leave these commented out to use defaults.
# Uncomment and change values to customize behavior.

# LLM Model
# Options: anthropic/claude-opus-4.6, anthropic/claude-sonnet-4-20250514,
#          openai/gpt-4o, openai/gpt-4o-mini
# Default: anthropic/claude-opus-4.6
# STEPH_MODEL=anthropic/claude-opus-4.6

# Temperature (0-20, divide by 10 to get actual value)
# 0-3: More focused (e.g., "3" = 0.3)
# 5-7: Balanced, recommended (e.g., "7" = 0.7)
# 8-12: More creative (e.g., "10" = 1.0)
# Default: 7
# STEPH_TEMPERATURE=7

# Maximum tokens per response
# 512: Short responses
# 1024: Medium responses (default)
# 2048: Longer responses
# Default: 1024
# STEPH_MAX_OUTPUT_TOKENS=1024

# Rate limiting: max requests per window
# Default: 10
# STEPH_RATE_LIMIT_MAX=10

# Rate limiting: time window in seconds
# Default: 60 (1 minute)
# STEPH_RATE_LIMIT_WINDOW_SECONDS=60

# Conversation timeout in milliseconds
# How long a conversation stays active (messages within this window are grouped together)
# 3600000 = 1 hour (default)
# 1800000 = 30 minutes
# Default: 3600000
# STEPH_CONVERSATION_TIMEOUT_MS=3600000

# RAG similarity threshold (0.0 - 1.0)
# Higher = stricter matching, fewer results. Lower = more results, less precise.
# Default: 0.4
# STEPH_RAG_SIMILARITY_THRESHOLD=0.4
